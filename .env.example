# US Visa Bot Configuration
# Copy this file to .env and fill in your actual values

# Your credentials for https://ais.usvisa-info.com/
EMAIL=your.email@example.com
PASSWORD=your_password_here

# Locale/language setting - can be found in the URL when trying to reschedule
# Examples: 'fr-fr' for France, 'pt-br' for Brazil, 'en-us' for United States
LOCALE=en-us

# Schedule ID - found in the URL when trying to reschedule manually
# URL format: https://ais.usvisa-info.com/{LOCALE}/niv/schedule/{SCHEDULE_ID}/continue_actions
SCHEDULE_ID=12345678

# Facility IDs - comma-separated list of facilities to monitor
# Found in network calls when selecting a new date or inspecting the selector
# The bot will check all and pick the earliest available date
# Example: FACILITY_IDS=44,45,89
FACILITY_IDS=44

# Refresh delay in seconds between cycles (default 3600 = 1 hour)
REFRESH_DELAY=3600

# Active hours (24-hour format) — bot rests outside these hours
ACTIVE_HOURS_START=7
ACTIVE_HOURS_END=23

# Telegram notifications (optional - leave empty to disable)
# Create a bot via @BotFather on Telegram to get your token
# Send a message to your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Pushover emergency alerts (optional - loud alarm that bypasses DND)
# Sign up at https://pushover.net ($5 one-time), install the app, then fill these in
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# Minimum days earlier than current booking required to rebook (default 7)
# Prevents wasting reschedule attempts on marginal improvements
MIN_DATE_DIFFERENCE=7

# Seconds to wait after an authentication error before retrying (default 300 = 5 minutes)
AUTH_COOLDOWN=300

# Max consecutive login failures before the bot stops (default 3)
MAX_LOGIN_FAILURES=3